/* 全局样式 - 紫色主题 */
page {
  background-color: #E8F4FC;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4A90D9 0%, #6A5FAA 100%);
  color: white;
  border-radius: 16rpx;
  padding: 28rpx 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin: 16rpx 0;
  box-shadow: 0 6rpx 20rpx rgba(124, 111, 188, 0.35);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: white;
  color: #4A90D9;
  border-radius: 16rpx;
  padding: 28rpx 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: 2rpx solid #D4CEEF;
  margin: 16rpx 0;
}

.btn-secondary::after {
  border: none;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 24rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(124, 111, 188, 0.08);
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #4A3F8C;
  margin-bottom: 24rpx;
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #EDE9F7;
  border-top: 4rpx solid #4A90D9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #4A90D9;
  margin-top: 20rpx;
  font-weight: 500;
}

/* 提示信息 */
.hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin: 10rpx 0;
}

/* 错误信息 */
.error {
  font-size: 28rpx;
  color: #e74c3c;
  text-align: center;
  padding: 24rpx;
  background: #fdf2f2;
  border-radius: 12rpx;
  margin: 20rpx 0;
}

/* 成功信息 */
.success {
  font-size: 28rpx;
  color: #4A90D9;
  text-align: center;
  padding: 24rpx;
  background: #E8F4FC;
  border-radius: 12rpx;
  margin: 20rpx 0;
  font-weight: 600;
}
